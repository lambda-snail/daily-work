@page "/todos"

@using Microsoft.FluentUI.AspNetCore.Components
@using Microsoft.FluentUI.AspNetCore.Components.Icons.Filled
@using Server.Components.Components

<FluentToolbar id="todo-toolbar" Style="width: 100%">
    <label slot="label">Manage Todos</label>
    <FluentButton
        Appearance="Appearance.Accent"
        OnClick="AddTodo"
        IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.AddSquare())">
        New
    </FluentButton>
    
    <FluentButton
        Appearance="Appearance.Lightweight"
        IconStart="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Delete())">
        Remove
    </FluentButton>
    
    <FluentTextField slot="end" Placeholder="Search"></FluentTextField>
    <FluentIcon slot="end" Value="@(new Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Globe())"
        Icon="@(Microsoft.FluentUI.AspNetCore.Components.Icons.Regular.Size20.Globe)" />
    
    
