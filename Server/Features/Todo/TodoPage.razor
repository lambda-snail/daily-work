    @* <FluentCheckbox @bind-Value=check1>Checkbox</FluentCheckbox> *@
</FluentToolbar>

<FluentStack HorizontalAlignment="HorizontalAlignment.Stretch">
    
    <FluentCard Width="400px">
        
        @if (_currentTodo is not null)
        {
            <h4>@_currentTodo?.Title</h4>
            <p> <InlineEditableText Mode="InlineEditableText.InputMode.TextArea" @bind-Value="@_currentTodo!.Description" ></InlineEditableText></p>
            
            <FluentGrid Justify="JustifyContent.FlexStart" Spacing="3">
                <FluentGridItem xs="12">
                    <FluentSortableList @ref="_itemList" Items="@_currentTodoItems" OnUpdate="@SortList">
                        <ItemTemplate>
                            <FluentStack @key="@context.Id" Orientation="Orientation.Horizontal">
                                <FluentCheckbox @bind-Value="@context.IsDone"></FluentCheckbox>
                                <InlineEditableText Mode="InlineEditableText.InputMode.TextField" @bind-Value="@context.Text"></InlineEditableText>
                            </FluentStack>
                        </ItemTemplate>
                    </FluentSortableList>
                </FluentGridItem>
            </FluentGrid>
        }
        else
        {
            <p>No todo selected</p>
        }

    </FluentCard>
    
    <FluentGrid Justify="JustifyContent.FlexStart" Spacing="3" Style="width: 50%">
        <FluentGridItem xs="12">
            <FluentSortableList Items="_items" OnUpdate="@SortList" Selection="Selection">
                <ItemTemplate>
                    <FluentStack  Orientation="Orientation.Horizontal" onclick="@(() => SetCurrentTodo(@context))">
                        @context.Title
                        @if (context.Id == _currentTodo?.Id)
                        {
                            <FluentBadge Appearance="Appearance.Neutral">Current</FluentBadge>
                        }
                        <FluentSpacer/>
                        <FluentBadge Appearance="Appearance.Accent">New</FluentBadge>
                        @DateOnly.FromDateTime(DateTime.Now)
                    </FluentStack>
                </ItemTemplate>
            </FluentSortableList>
        </FluentGridItem>
    </FluentGrid>    
    
</FluentStack>
