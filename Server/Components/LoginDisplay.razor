@using Microsoft.AspNetCore.Components.Authorization
@* <AuthorizeView> *@
@*     <Authorized> *@
@*         Hello, @context.User.Identity?.Name *@
@*         <a class="btn btn-sm btn-secondary" href="/MicrosoftIdentity/Account/SignOut" style="text-decoration:none;"> *@
@*             <span class="oi oi-account-logout" aria-hidden="true"></span> *@
@*             Logout *@
@*         </a> *@
@*     </Authorized> *@
@*     <NotAuthorized> *@
@*         <a class="btn btn-sm btn-secondary" href="/MicrosoftIdentity/Account/SignIn" style="text-decoration:none;"> *@
@*             <span class="oi oi-account-login" aria-hidden="true"></span> *@
@*             Login *@
@*         </a> *@
@*     </NotAuthorized> *@
@* </AuthorizeView> *@

<FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center">

    <FluentCard Style="width:25%; height: 10rem;">
        
        @* <FluentLabel Typo="Typography.HeroTitle">Welcome to Daily Work</FluentLabel> *@
        @* <FluentLabel Typo="Typography.PageTitle">The center for all your work tracking</FluentLabel> *@
        
        <FluentStack Orientation="Orientation.Vertical"
                     HorizontalAlignment="HorizontalAlignment.Center"
                     VerticalAlignment="VerticalAlignment.Center">

            <FluentButton
                Style="width: 100%"
                OnClick="@(() => NavigationManager.NavigateTo("/MicrosoftIdentity/Account/SignIn", new NavigationOptions()
                         {
                             ForceLoad = true
                         }))">
                Sign In
            </FluentButton>

            <FluentButton
                Style="width: 100%"
                OnClick="@(() => NavigationManager.NavigateTo("/MicrosoftIdentity/Account/SignUp", new NavigationOptions()
                         {
                             ForceLoad = true
                         }))">
                Sign Up
            </FluentButton>
        </FluentStack>
    </FluentCard>

</FluentStack>

@code {

    [Inject] public NavigationManager NavigationManager { get; set; }
    
}