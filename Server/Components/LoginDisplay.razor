
<FluentStack Orientation="Orientation.Vertical" HorizontalAlignment="HorizontalAlignment.Center">

    <FluentCard Style="width:50%;margin:2rem;">
        
        <FluentStack Orientation="Orientation.Vertical"
                     HorizontalAlignment="HorizontalAlignment.Center"
                     VerticalAlignment="VerticalAlignment.Center">
            
            <FluentLabel Typo="Typography.HeroTitle">Welcome to Daily Work</FluentLabel>
            <FluentLabel Typo="Typography.H4">The center for all your work tracking</FluentLabel>
            
            <FluentSpacer />

            <FluentButton
                Style="width: 100%"
                OnClick="@(() => NavigationManager.NavigateTo("/MicrosoftIdentity/Account/SignIn", new NavigationOptions()
                         {
                             ForceLoad = true
                         }))">
                Sign In
            </FluentButton>

            <FluentButton
                Style="width: 100%"
                OnClick="@(() => NavigationManager.NavigateTo("/MicrosoftIdentity/Account/SignUp", new NavigationOptions()
                         {
                             ForceLoad = true
                         }))">
                Sign Up
            </FluentButton>
        </FluentStack>
    </FluentCard>

</FluentStack>

@code {

    [Inject] public NavigationManager NavigationManager { get; set; }
    
}