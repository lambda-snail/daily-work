@inherits LayoutComponentBase

<FluentDesignTheme @bind-Mode="@Mode" OfficeColor="OfficeColor.Office" />

<FluentLayout>
    <FluentHeader>
        <FluentStack Orientation="Orientation.Horizontal" HorizontalAlignment="HorizontalAlignment.SpaceBetween">
            Daily Work
            
            <FluentProfileMenu Initials="BG" Style="padding: 4px;" TopCorner="true" >
                <StartTemplate>
                    John Doe
                </StartTemplate>
                <HeaderTemplate>
                    <FluentLabel Typo="@Typography.Header">Login</FluentLabel>
                </HeaderTemplate>
                <ChildContent>
                    <div style="width: 250px; height: 80px">
                        <FluentLabel Typo="@Typography.Header" Style="font-weight: bold;">John Doe</FluentLabel>
                        <FluentLabel>j.doe@contoso.com</FluentLabel>
                    </div>
                </ChildContent>
                <FooterTemplate>
                    <FluentStack>
                        <FluentSpacer />
                        <FluentAnchor Appearance="@Appearance.Hypertext"
                                      Href="https://contoso.com"
                                      Target="_blank">About</FluentAnchor>
                    </FluentStack>
                </FooterTemplate>
            </FluentProfileMenu>
            
        </FluentStack>
    </FluentHeader>
    <FluentStack Class="main" Orientation="Orientation.Horizontal" Width="100%">
        <NavMenu />
        <FluentBodyContent Class="body-content">
           
            <div class="content">
                @Body
            </div>
            <FluentToastProvider MaxToastCount="10" />
            <FluentDialogProvider />
            <FluentTooltipProvider />
            <FluentMessageBarProvider Section="MESSAGES_TOP"/>
            <FluentMenuProvider />
            
        </FluentBodyContent>
    </FluentStack>
    <FluentFooter>
        <a href="https://www.fluentui-blazor.net" target="_blank">Documentation and demos</a>
        <FluentSpacer />
        <a href="https://learn.microsoft.com/en-us/aspnet/core/blazor" target="_blank">About Blazor</a>
    </FluentFooter>
</FluentLayout>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {

    public DesignThemeModes Mode { get; set; } = DesignThemeModes.Dark;

    private void UpdateMode()
    {
        Mode = (Mode == DesignThemeModes.Dark ? DesignThemeModes.Light : DesignThemeModes.Dark);
        StateHasChanged();
    }

}